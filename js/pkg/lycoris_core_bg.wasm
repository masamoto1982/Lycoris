# WASMバイナリヘッダー表現（実際はバイナリファイル）
00 61 73 6D 01 00 00 00  # WASM Magic Number & Version
01 07 01 60 02 7F 7F 01  # Type Section
7F 02 0C 01 03 65 6E 76  # Import Section
06 6D 65 6D 6F 72 79 02  # Memory Import
00 01 03 02 01 00 07 11  # Function & Export Sections
01 0D 6C 79 63 6F 72 69  # "lycoris" export
73 5F 69 6E 69 74 00 00  # init function
... (約100KB のバイナリデータ)
